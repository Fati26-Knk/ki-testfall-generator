## Copy this file to `.env` and fill in your OpenAI API key to enable real LLM generation.
# Do NOT commit your real `.env` with secret keys to version control.

# OpenAI API Key (example):
OPENAI_API_KEY=

# Optional: override model name, e.g. gpt-4o-mini or gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Optional CORS origins (comma-separated)
#CORS_ORIGINS=*
# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
