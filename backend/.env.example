OPENAI_API_KEY=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
